# Hub API
HUB_API_URL=http://localhost:3001

# SMTP Configuration
SMTP_HOST=smtp.eu.mailgun.org
SMTP_PORT=587
SMTP_USER=website@decodedops.co.uk
SMTP_PASS=your-mailgun-smtp-password
SMTP_FROM=website@decodedops.co.uk

# Contact Form
CONTACT_EMAIL=craig@decodedops.co.uk

# Auth — Client Portal
NEXTAUTH_SECRET=generate-with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_URL=https://decodedops.co.uk

# Database — plain Postgres (dedicated VPS), NOT Supabase.
# `lib/supabase.ts` is named for the client-portal tables it reads but is a
# plain `pg` Pool, same pattern as the hub's `supabase-pg.ts` shim.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Upstash Redis (for rate limiting) — optional, degrades gracefully if unset
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token
